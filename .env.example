# ── Database backend ──────────────────────────────────────────
# Set to "production" on the deployed cPanel Python App
APP_ENV=development

# Set to "mysql" for MySQL, "supabase" for Supabase
DB_BACKEND=mysql

# ── MySQL connection ──────────────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=habelite_recon
MYSQL_USER=recon_user
MYSQL_PASSWORD=your_password_here

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here_minimum_32_characters

# ── Supabase connection ───────────────────────────────────────
# Required instead of MySQL values when DB_BACKEND=supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# ── File storage ──────────────────────────────────────────────
# Local path where reconciliation output files are saved
RECON_OUTPUT_DIR=/path/to/recon_outputs


# ── PHP Portal ────────────────────────────────────────────────
# API_BASE_URL=https://medical-aid-recon-bot.onrender.com
